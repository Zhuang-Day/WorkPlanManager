# 只需要這一個變數。要連 Supabase 或本機都放這裡
# Supabase 範例（建議用 Pooler 並加 sslmode=require）：
# DATABASE_URL=postgresql+psycopg2://postgres.<PROJECT>:<PASSWORD>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# 本機 PostgreSQL 範例（不需要 SSL）：
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/postgres
